{
  "//": "Uptime Monitor plugin tsconfig — same path setup as the showcase plugin so the IDE resolves @instatic/* against host source for type-check.",
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "paths": {
      "@instatic/host-ui": ["../../../src/core/plugin-host-ui/index.ts"],
      "@instatic/host-hooks": ["../../../src/core/plugin-host-hooks/index.ts"],
      "@instatic/plugin-sdk": ["../../../src/core/plugin-sdk/index.ts"],
      "@core/*": ["../../../src/core/*"]
    }
  },
  "include": ["instatic-plugin.config.ts", "admin/**/*", "server/**/*"]
}
