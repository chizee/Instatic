{
  "//": "First-party plugin tsconfig — wires the @pagebuilder/* virtual packages back to host source for IDE / type-check support. The runtime resolution at build time is handled by `pb-plugin build`'s externals + the host's import map (see public/runtime/).",
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "paths": {
      "@pagebuilder/host-ui": ["../../../src/core/plugin-host-ui/index.ts"],
      "@pagebuilder/host-hooks": ["../../../src/core/plugin-host-hooks/index.ts"],
      "@pagebuilder/plugin-sdk": ["../../../src/core/plugin-sdk/index.ts"],
      "@core/*": ["../../../src/core/*"]
    }
  },
  "include": [
    "pb-plugin.config.ts",
    "admin/**/*",
    "editor/**/*",
    "frontend/**/*",
    "modules/**/*",
    "pack/**/*",
    "server/**/*"
  ]
}
